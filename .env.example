# Copy to .env.local and fill in your values
# Add all of these to Vercel → Settings → Environment Variables too

# From Supabase → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJyour-anon-key

# From the JSON your SAP account owner gave you
SAP_AUTH_URL=paste-the-url-field-here
SAP_CLIENT_ID=paste-the-clientid-field-here
SAP_CLIENT_SECRET=paste-the-clientsecret-field-here
SAP_AI_API_URL=https://api.ai.prod-us21.eastus.azure.ml.hana.ondemand.com
RESOURCE_GROUP=default
