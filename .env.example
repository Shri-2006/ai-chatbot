# Copy to .env.local and fill in your values
# Add all of these to Vercel → Settings → Environment Variables too

# ── Supabase (from Project Settings → API) ────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJyour-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJyour-service-role-key

# ── SAP AI Core (from the JSON your SAP account owner gave you) ───────────────
SAP_AUTH_URL=paste-the-url-field-here
SAP_CLIENT_ID=paste-the-clientid-field-here
SAP_CLIENT_SECRET=paste-the-clientsecret-field-here
SAP_AI_API_URL=https://api.ai.prod-us21.eastus.azure.ml.hana.ondemand.com
SAP_ORCHESTRATION_DEPLOYMENT_ID=paste-your-deployment-id-here
RESOURCE_GROUP=default

# ── HuggingFace (optional — required for vector RAG + vector memory) ──────────
# Without this, RAG falls back to keyword search and vector memory is disabled
# Get a free token at https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your-token-here

# ── SearXNG (optional — recommended for full web search) ─────────────────────
# Without this, web search falls back to DuckDuckGo instant answers only
SEARXNG_URL=https://your-space-name.hf.space